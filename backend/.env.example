# Server configuration (copy to .env and adjust for production)
PORT=4000
NODE_ENV=development

# Frontend origin(s) allowed to call the API (comma separated)
CORS_ORIGIN=http://localhost:4321,http://localhost:4400,http://localhost:4406

# Session + token settings
SESSION_SECRET=dev-session-secret-change-me-in-production
SESSION_TTL_HOURS=24
REMEMBER_ME_TTL_DAYS=30

# Security
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# Supabase — auth, database, and user/game progress storage.
# Project URL and keys from the Supabase dashboard (Project Settings → API).
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public base URL of this API, exposed to the frontend at build time.
PUBLIC_API_URL=http://localhost:4000
