---
preserveScript:true
import Layout from "../layouts/Layout.astro";

interface GuideItem {
  heading: string;
  body: string;
}

interface Props {
  title: string;
  description: string;
  genre: string[];
  guide: GuideItem[];
}

const { title, description, genre, guide } = Astro.props;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "VideoGame",
  name: title,
  genre: genre,
  gamePlatform: ["Web", "Browser"],
  operatingSystem: "Any",
  applicationCategory: "Game",
  description: description,
};
---

<Layout title={`${title} — YOUTUBE PLAYABLES`}>
  <a href="#main" class="skip-link">Skip to content</a>

  <header class="sticky top-0 z-50 h-16 border-b border-hairline bg-canvas/80 backdrop-blur-md">
    <nav class="mx-auto flex h-16 max-w-[1400px] items-center justify-between px-6">
      <a href="/" class="flex items-center gap-2">
        <svg width="22" height="22" viewBox="0 0 24 24" aria-hidden="true">
          <rect width="24" height="24" rx="5" fill="#171717"></rect>
          <path d="M10 8.5v7l5.5-3.5L10 8.5z" fill="#fff"></path>
        </svg>
        <span class="text-sm font-semibold tracking-tight text-ink">YOUTUBE PLAYABLES</span>
      </a>
      <div class="hidden items-center gap-1 md:flex">
        <a href="/playables" class="rounded-full bg-canvas-soft px-3 py-1.5 text-sm text-ink">Playables</a>
      </div>
      <div class="flex items-center gap-2">
        <a href="/login" class="hidden h-7 items-center rounded-sm border border-hairline px-3 text-sm font-medium text-ink hover:bg-canvas-soft sm:inline-flex">Log In</a>
        <a href="/signup" class="inline-flex h-7 items-center rounded-sm bg-ink px-3 text-sm font-medium text-white">Sign Up</a>
      </div>
    </nav>
  </header>

  <main id="main">
    <section class="relative overflow-hidden border-b border-hairline">
      <div class="mesh-soft pointer-events-none absolute inset-0" aria-hidden="true"></div>
      <div class="relative mx-auto max-w-[1400px] px-6 py-16">
        <a href="/playables" class="font-mono text-xs text-link underline-offset-4 hover:underline">← All playables</a>
        <div class="mt-4">
          <span class="mb-3 inline-block rounded-full bg-canvas px-3 py-1 font-mono text-xs text-mute shadow-[0_0_0_1px_#00000014]">Playables</span>
          <h1 class="max-w-2xl text-[36px] font-semibold leading-[1.05] tracking-[-2px] text-ink sm:text-[48px]">{title}.</h1>
          <p class="mt-4 max-w-xl text-lg leading-7 text-body">{description}</p>
        </div>

        <div class="mt-10 flex flex-col items-center">
          <div id="game-wrap" class="relative w-full max-w-[480px] overflow-hidden rounded-xl border border-hairline bg-ink shadow-[0_1px_1px_#00000005,0_2px_2px_#0000000a]">
            <div id="board" class="flex w-full h-[520px] flex-col items-center justify-center px-6 text-center text-white">
              <slot />
            </div>
          </div>

          <button id="reset-btn" type="button" class="mt-6 inline-flex h-10 items-center rounded-pill border border-hairline bg-canvas px-6 text-sm font-medium text-ink hover:bg-canvas-soft">New game</button>
          <p id="status" class="mt-3 min-h-[1.25rem] font-mono text-sm text-mute"></p>
        </div>

        <div id="over-screen" class="absolute inset-0 z-20 hidden flex-col items-center justify-center gap-3 bg-ink/85 px-6 text-center text-white pointer-events-auto">
          <h2 id="over-title" class="text-3xl font-semibold tracking-tight">Game Over</h2>
          <p id="over-msg" class="max-w-xs text-sm text-white/80"></p>
          <button id="over-again" type="button" class="mt-2 inline-flex h-11 items-center rounded-pill bg-white px-8 text-sm font-semibold text-ink hover:opacity-90">Play again</button>
        </div>
      </div>
    </section>

    <section class="px-6 py-16">
      <div class="mx-auto max-w-[1400px]">
        <h2 class="text-2xl font-semibold tracking-tight text-ink">How to play {title}</h2>
        <div class="mt-8 grid gap-6 md:grid-cols-2">
          {
            guide.map((g) => (
              <div class="rounded-lg border border-hairline bg-canvas p-6 shadow-[0_1px_1px_#00000005,0_2px_2px_#0000000a]">
                <h3 class="text-lg font-semibold text-ink">{g.heading}</h3>
                <p class="mt-2 text-sm leading-6 text-body">{g.body}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>
  </main>

  <footer class="border-t border-hairline bg-canvas px-6 py-16">
    <div class="mx-auto flex max-w-[1400px] flex-col items-start justify-between gap-2 border-t border-hairline pt-6 text-sm text-mute sm:flex-row sm:items-center">
      <span>© {new Date().getFullYear()} YOUTUBE PLAYABLES. All rights reserved.</span>
      <span class="font-mono text-xs">youtubeplayables</span>
    </div>
  </footer>

  <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)}></script>

<script is:inline>
      window.__showOver = (title, msg) => {
        const screen = document.getElementById('over-screen');
        if (title) document.getElementById('over-title').textContent = title;
        if (msg) document.getElementById('over-msg').textContent = msg;
        screen.classList.remove('hidden');
        screen.classList.add('flex');
      };
      
      window.__hideOver = () => {
        const screen = document.getElementById('over-screen');
        if (screen) {
          screen.classList.add('hidden');
          screen.classList.remove('flex');
        }
      };
      
      document.getElementById('over-again').addEventListener('click', () => {
        window.__hideOver();
        if (typeof window.__resetGame === 'function') window.__resetGame();
      });
    </script>
</Layout>