---
import { games, popularGames } from "../shared/games";
import { SITE_NAME } from "../shared/config";
import Logo from "./Logo.astro";
import DarkModeToggle from "./DarkModeToggle.astro";
---

<footer class="border-t border-hairline bg-canvas px-6 py-16">
  <div class="mx-auto grid max-w-[1400px] gap-10 md:grid-cols-4">
    <div class="md:col-span-1">
      <div class="flex items-center gap-2">
        <Logo />
        <span class="text-sm font-semibold tracking-tight text-ink">{SITE_NAME}</span>
      </div>
      <p class="mt-4 text-sm text-body">Free browser-native HTML5 games.</p>
      <p class="mt-2 text-sm text-body">
        <a href="mailto:calgroupofficial@gmail.com" class="text-link underline-offset-4 hover:underline">calgroupofficial@gmail.com</a>
      </p>
    </div>

    <div>
      <p class="mb-3 font-mono text-xs uppercase tracking-wide text-mute">Games</p>
      <ul class="space-y-2 text-sm text-body">
        {popularGames(5).map((g) => (
          <li><a href={`/${g.id}`} class="hover:text-ink">{g.title}</a></li>
        ))}
        <li><a href="/playables" class="hover:text-ink">View all games →</a></li>
      </ul>
    </div>

    <div>
      <p class="mb-3 font-mono text-xs uppercase tracking-wide text-mute">Explore</p>
      <ul class="space-y-2 text-sm text-body">
        <li><a href="/playables" class="hover:text-ink">All playables</a></li>
        <li><a href="/blog" class="hover:text-ink">Blog</a></li>
      </ul>
    </div>

    <div>
      <p class="mb-3 font-mono text-xs uppercase tracking-wide text-mute">Company</p>
      <ul class="space-y-2 text-sm text-body">
        <li><a href="/about" class="hover:text-ink">About</a></li>
        <li><a href="/contact" class="hover:text-ink">Contact</a></li>
        <li><a href="/privacy" class="hover:text-ink">Privacy Policy</a></li>
        <li><a href="/terms" class="hover:text-ink">Terms</a></li>
      </ul>
    </div>
  </div>

  <div
    class="mx-auto mt-12 flex max-w-[1400px] flex-col items-start justify-between gap-4 border-t border-hairline pt-6 text-sm text-mute sm:flex-row sm:items-center"
  >
    <span>© {new Date().getFullYear()} {SITE_NAME}. All rights reserved.</span>
    <div class="flex items-center gap-3">
      <DarkModeToggle />
      <span class="font-mono text-xs">youtubeplayables</span>
    </div>
  </div>
</footer>
