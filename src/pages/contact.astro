---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Contact — YOUTUBE PLAYABLES" description="Get in touch with YOUTUBE PLAYABLES for support, feedback, or partnership questions.">
  <a href="#main" class="skip-link">Skip to content</a>
  <main id="main" class="mx-auto max-w-[1400px] px-6 py-24">
    <h1 class="text-4xl font-semibold tracking-tight text-ink">Contact.</h1>
    <p class="mt-4 max-w-3xl text-lg leading-7 text-body">Have a question, feedback, or partnership idea? Reach out and we’ll get back to you.</p>

    <div class="mt-10 grid gap-6 md:grid-cols-2">
      <div class="rounded-lg border border-hairline bg-canvas p-6">
        <h2 class="text-lg font-semibold text-ink">Email</h2>
        <p class="mt-2 text-body"><a href="mailto:calgroupofficial@gmail.com" class="text-link underline-offset-4 hover:underline">calgroupofficial@gmail.com</a></p>
      </div>
      <div class="rounded-lg border border-hairline bg-canvas p-6">
        <h2 class="text-lg font-semibold text-ink">Support</h2>
        <p class="mt-2 text-body">For gameplay issues, controls questions, or troubleshooting, visit our <a href="/support" class="text-link underline-offset-4 hover:underline">Support</a> page first.</p>
      </div>
      <div class="rounded-lg border border-hairline bg-canvas p-6">
        <h2 class="text-lg font-semibold text-ink">Feedback</h2>
        <p class="mt-2 text-body">We read every message. Tell us which game you’d like improved, which feature matters most, or what broke.</p>
      </div>
      <div class="rounded-lg border border-hairline bg-canvas p-6">
        <h2 class="text-lg font-semibold text-ink">Partnerships</h2>
        <p class="mt-2 text-body">Interested in sponsoring a game or integrating with YOUTUBE PLAYABLES? Let’s talk at <a href="mailto:calgroupofficial@gmail.com" class="text-link underline-offset-4 hover:underline">calgroupofficial@gmail.com</a>.</p>
      </div>
    </div>

    <a href="/playables" class="mt-10 inline-block text-sm text-link underline-offset-4 hover:underline">← Back to playables</a>
  </main>
</Layout>
