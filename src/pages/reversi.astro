---
import GameShell from "../components/GameShell.astro";
import { getGame } from "../shared/games";
const game = getGame("reversi");
---
<GameShell game={game}>
  <div
    class="mx-auto w-full max-w-[min(420px,90vw)]"
    id="reversi-board"
  />
</GameShell>
<script>
  import { initGame } from "../games/reversi/scripts/game";
  initGame();
</script>
