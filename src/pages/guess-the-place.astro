---
import GameShell from "../components/GameShell.astro";
import { getGame } from "../shared/games";
const game = getGame("guess-the-place");
---
<GameShell game={game}>
  <div id="guess-the-place" class="mx-auto w-full max-w-[360px]"></div>
</GameShell>

<script>
  import { initGame } from "../games/guess-the-place/scripts/game";
  initGame();
</script>
