---
import GameShell from "../components/GameShell.astro";

const game = {
  title: "Stack Tower",
  description: "Drop blocks and stack them as high as possible. Align them carefully or the tower will topple!",
  genre: ["Arcade", "Puzzle"],
  guide: [
    { heading: "Goal", body: "Build the tallest stable tower before it collapses." },
    { heading: "How to play", body: "A block slides left-right at the top. Click or tap to drop it instantly. It locks onto the stack below — overhanging parts fall off. The new block's width becomes the overlap." },
    { heading: "Strategy", body: "Time your drops to center the block. Each level the speed increases. Even small overlaps continue the game but make the next block narrower." },
    { heading: "Example", body: "Stack is 200px wide. Moving block is 200px. Drop slightly off-center → 180px overlap. Next block is 180px wide. Keep going until overlap is 0." },
  ],
};
---

<GameShell title={game.title} description={game.description} genre={game.genre} guide={game.guide}>
  <div id="stack-container" class="relative w-full max-w-[min(360px,100vw-2rem)] mx-auto overflow-hidden" style="height: min(480px, 100dvh-10rem);"></div>
</GameShell>

<script>
function getDims() {
  const area = window.__getGameArea ? window.__getGameArea() : { w: 360, h: 480 };
  const w = Math.min(360, area.w);
  const bh = Math.max(16, Math.min(28, Math.floor(area.h / 18)));
  const h = Math.min(480, area.h);
  return { w, bh, h };
}

let dims = getDims();
let W = dims.w, BH = dims.bh, H = dims.h;

const container = document.getElementById('stack-container');
const resetBtn = document.getElementById('reset-btn');
const statusEl = document.getElementById('status');

let stack = [];
let moving = null;
let score = 0;
let over = false;
let raf = null;

function syncDims() {
  const d = getDims();
  if (d.w !== W || d.bh !== BH || d.h !== H) {
    const sx = d.w / W, sy = d.h / H;
    stack = stack.map(b => ({ x: b.x * sx, w: b.w * sx }));
    if (moving) { moving.x *= sx; moving.w *= sx; }
    W = d.w; BH = d.bh; H = d.h;
  }
}

function init() {
  syncDims();
  stack = [{ x: 0, w: W }];
  score = 0;
  over = false;
  statusEl.textContent = 'Score: 0';
  spawnMoving();
  draw();
}

function randX(maxWidth) {
  return Math.random() * (W - maxWidth);
}

function spawnMoving() {
  const below = stack[stack.length - 1];
  const w = Math.max(40, below.w * (0.7 + Math.random() * 0.3));
  moving = {
    x: randX(w),
    w,
    dir: Math.random() < 0.5 ? -1 : 1,
    speed: 2.0 + score * 0.08
  };
}

function drop() {
  if (over || !moving) return;
  const below = stack[stack.length - 1];
  const left = Math.max(moving.x, below.x);
  const right = Math.min(moving.x + moving.w, below.x + below.w);
  const overlap = right - left;

  if (overlap <= 0) {
    over = true;
    statusEl.textContent = 'Game Over! Score: ' + score;
    window.__showOver('Game Over!', 'Score: ' + score);
    return;
  }

  stack.push({ x: left, w: overlap });
  score++;
  statusEl.textContent = 'Score: ' + score;

  spawnMoving();
  draw();
}

function draw() {
  syncDims();
  container.innerHTML = '';
  const inner = document.createElement('div');
  inner.style.position = 'relative';
  inner.style.width = W + 'px';
  inner.style.height = (stack.length + 1) * BH + 'px';

  const totalH = stack.length * BH;
  const offset = Math.max(0, totalH - H);
  inner.style.transform = `translateY(${-offset}px)`;

  stack.forEach((b, i) => {
    const d = document.createElement('div');
    d.style.position = 'absolute';
    d.style.left = b.x + 'px';
    d.style.bottom = (i * BH) + 'px';
    d.style.width = b.w + 'px';
    d.style.height = BH + 'px';
    d.style.background = `hsl(${(i * 35) % 360}, 75%, 55%)`;
    d.style.border = '1px solid rgba(0,0,0,.2)';
    d.style.borderRadius = '2px';
    inner.appendChild(d);
  });

  if (moving && !over) {
    const d = document.createElement('div');
    d.style.position = 'absolute';
    d.style.left = moving.x + 'px';
    d.style.bottom = (stack.length * BH) + 'px';
    d.style.width = moving.w + 'px';
    d.style.height = BH + 'px';
    d.style.background = 'rgba(255,255,255,.9)';
    d.style.border = '1px solid rgba(0,0,0,.25)';
    d.style.borderRadius = '2px';
    inner.appendChild(d);
  }

  container.appendChild(inner);
}

function animate() {
  if (!over && moving) {
    moving.x += moving.dir * moving.speed;
    if (moving.x <= 0) { moving.x = 0; moving.dir = 1; }
    if (moving.x >= W - moving.w) { moving.x = W - moving.w; moving.dir = -1; }
    draw();
  }
  raf = requestAnimationFrame(animate);
}

function reset() {
  if (raf) cancelAnimationFrame(raf);
  init();
  animate();
}

resetBtn.addEventListener('click', reset);
container.addEventListener('click', drop);

init();
animate();

window.__resetGame = reset;
</script>