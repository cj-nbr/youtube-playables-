---
import Layout from "../layouts/Layout.astro";
import { games } from "../shared/games";
---

<Layout title="Changelog — YOUTUBE PLAYABLES" description="What's new on YOUTUBE PLAYABLES: platform upgrades, new games, and improvements.">
  <a href="#main" class="skip-link">Skip to content</a>
  <main id="main" class="mx-auto max-w-[1400px] px-6 py-24">
    <h1 class="text-4xl font-semibold tracking-tight text-ink">Changelog.</h1>
    <p class="mt-4 max-w-xl text-lg text-body">A running log of platform upgrades, new games, and quality improvements.</p>
    <div class="mt-12 space-y-8">
      <div class="rounded-lg border border-hairline bg-canvas p-6">
        <p class="font-mono text-xs text-mute">PLATFORM UPGRADE</p>
        <h2 class="mt-1 text-lg font-semibold text-ink">Production platform rebuild</h2>
        <p class="mt-2 text-body">Every game is now isolated in its own folder with shared, reusable utilities. Added SEO, structured data, player instructions, FAQs, related games, high-score tracking, sound, pause, and accessibility improvements across all {games.length} titles.</p>
      </div>
      <div class="rounded-lg border border-hairline bg-canvas p-6">
        <p class="font-mono text-xs text-mute">LIBRARY</p>
        <h2 class="mt-1 text-lg font-semibold text-ink">{games.length} games available</h2>
        <p class="mt-2 text-body">Tic Tac Toe, Stack Tower, Color Match, Block Blast, Number Slide, Memory Flip, Chess, and Dots and Boxes — all free and browser-native.</p>
      </div>
    </div>
    <a href="/playables" class="mt-10 inline-block text-sm text-link underline-offset-4 hover:underline">← Back to playables</a>
  </main>
</Layout>
