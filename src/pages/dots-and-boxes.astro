---
import GameShell from "../components/GameShell.astro";

const game = {
  title: "Dots and Boxes",
  description: "Draw lines to complete squares. Claim the most boxes to win!",
  genre: ["Strategy", "Puzzle"],
  guide: [
    { heading: "Goal", body: "Claim the most squares (boxes) by completing their fourth side." },
    { heading: "How to play", body: "Players take turns clicking a line between two adjacent dots. When a line completes a square, that player claims it and gets another turn. Otherwise play passes." },
    { heading: "Strategy", body: "Avoid giving your opponent a 'free' line. Chain completions: one move can close several boxes at once." },
    { heading: "Example", body: "4×4 dots form 3×3 = 9 boxes. If you draw the last open side around a box, you paint it your color and move again." },
  ],
};
---

<GameShell title={game.title} description={game.description} genre={game.genre} guide={game.guide}>
  <div id="dots" class="mx-auto"></div>
  <div class="mt-3 flex items-center justify-center gap-6 font-mono text-sm">
    <span id="p1-score" class="text-[#19a0ff]">P1: 0</span>
    <span id="turn" class="text-white/80">Player 1's turn</span>
    <span id="p2-score" class="text-[#ff4d4d]">P2: 0</span>
  </div>
</GameShell>

<script>
const N = 4;            // dots per side -> (N-1) boxes per side
const GAP = 70;
const START = 36;
const SIZE = START * 2 + (N - 1) * GAP;

const gameEl = document.getElementById('dots');
const resetBtn = document.getElementById('reset-btn');
const statusEl = document.getElementById('status');
const turnEl = document.getElementById('turn');
const p1El = document.getElementById('p1-score');
const p2El = document.getElementById('p2-score');

let hLines, vLines, boxes, current, scores, gameOver;

function init() {
  hLines = Array.from({ length: N }, () => Array(N - 1).fill(null));
  vLines = Array.from({ length: N - 1 }, () => Array(N).fill(null));
  boxes = Array.from({ length: N - 1 }, () => Array(N - 1).fill(null));
  current = 1;
  scores = { 1: 0, 2: 0 };
  gameOver = false;
  turnEl.textContent = "Player 1's turn";
  p1El.textContent = 'P1: 0';
  p2El.textContent = 'P2: 0';
  statusEl.textContent = '';
  draw();
}

const color = (p) => (p === 1 ? '#19a0ff' : '#ff4d4d');

function draw() {
  const svgNS = 'http://www.w3.org/2000/svg';
  const svg = document.createElementNS(svgNS, 'svg');
  svg.setAttribute('width', SIZE);
  svg.setAttribute('height', SIZE);
  svg.style.maxWidth = '100%';

  // boxes (filled)
  for (let r = 0; r < N - 1; r++) {
    for (let c = 0; c < N - 1; c++) {
      if (boxes[r][c]) {
        const rect = document.createElementNS(svgNS, 'rect');
        const x = START + c * GAP + 6;
        const y = START + r * GAP + 6;
        rect.setAttribute('x', x);
        rect.setAttribute('y', y);
        rect.setAttribute('width', GAP - 12);
        rect.setAttribute('height', GAP - 12);
        rect.setAttribute('rx', '4');
        rect.setAttribute('fill', color(boxes[r][c]));
        rect.setAttribute('opacity', '0.35');
        svg.appendChild(rect);
        const t = document.createElementNS(svgNS, 'text');
        t.setAttribute('x', START + c * GAP + GAP / 2);
        t.setAttribute('y', START + r * GAP + GAP / 2 + 6);
        t.setAttribute('text-anchor', 'middle');
        t.setAttribute('font-size', '18');
        t.setAttribute('font-family', 'monospace');
        t.setAttribute('fill', color(boxes[r][c]));
        t.textContent = 'P' + boxes[r][c];
        svg.appendChild(t);
      }
    }
  }

  // dots
  for (let r = 0; r < N; r++) {
    for (let c = 0; c < N; c++) {
      const dot = document.createElementNS(svgNS, 'circle');
      dot.setAttribute('cx', START + c * GAP);
      dot.setAttribute('cy', START + r * GAP);
      dot.setAttribute('r', '4');
      dot.setAttribute('fill', '#ffffff');
      svg.appendChild(dot);
    }
  }

  // horizontal lines
  for (let r = 0; r < N; r++) {
    for (let c = 0; c < N - 1; c++) {
      const taken = hLines[r][c];
      const x1 = START + c * GAP, x2 = START + (c + 1) * GAP, y = START + r * GAP;
      const line = document.createElementNS(svgNS, 'line');
      line.setAttribute('x1', x1); line.setAttribute('y1', y);
      line.setAttribute('x2', x2); line.setAttribute('y2', y);
      line.setAttribute('stroke', taken ? color(taken) : 'rgba(255,255,255,0.25)');
      line.setAttribute('stroke-width', taken ? '4' : '2');
      svg.appendChild(line);
      if (!taken) {
        const hit = document.createElementNS(svgNS, 'rect');
        hit.setAttribute('x', x1); hit.setAttribute('y', y - 10);
        hit.setAttribute('width', GAP); hit.setAttribute('height', '20');
        hit.setAttribute('fill', 'transparent');
        hit.style.cursor = 'pointer';
        hit.addEventListener('click', () => claimH(r, c));
        svg.appendChild(hit);
      }
    }
  }

  // vertical lines
  for (let c = 0; c < N; c++) {
    for (let r = 0; r < N - 1; r++) {
      const taken = vLines[r][c];
      const x = START + c * GAP, y1 = START + r * GAP, y2 = START + (r + 1) * GAP;
      const line = document.createElementNS(svgNS, 'line');
      line.setAttribute('x1', x); line.setAttribute('y1', y1);
      line.setAttribute('x2', x); line.setAttribute('y2', y2);
      line.setAttribute('stroke', taken ? color(taken) : 'rgba(255,255,255,0.25)');
      line.setAttribute('stroke-width', taken ? '4' : '2');
      svg.appendChild(line);
      if (!taken) {
        const hit = document.createElementNS(svgNS, 'rect');
        hit.setAttribute('x', x - 10); hit.setAttribute('y', y1);
        hit.setAttribute('width', '20'); hit.setAttribute('height', GAP);
        hit.setAttribute('fill', 'transparent');
        hit.style.cursor = 'pointer';
        hit.addEventListener('click', () => claimV(r, c));
        svg.appendChild(hit);
      }
    }
  }

  gameEl.innerHTML = '';
  gameEl.appendChild(svg);
}

function boxesAround(r, c) {
  // returns list of [boxR, boxC] that share the line at horizontal (r,c)
  const res = [];
  if (r > 0) res.push([r - 1, c]);
  if (r < N - 1) res.push([r, c]);
  return res;
}
function boxesAroundV(r, c) {
  const res = [];
  if (c > 0) res.push([r, c - 1]);
  if (c < N - 1) res.push([r, c]);
  return res;
}

function isComplete(bR, bC) {
  return hLines[bR][bC] && hLines[bR + 1][bC] && vLines[bR][bC] && vLines[bR][bC + 1];
}

function claimH(r, c) {
  if (gameOver || hLines[r][c]) return;
  hLines[r][c] = current;
  finishTurn(boxesAround(r, c));
}
function claimV(r, c) {
  if (gameOver || vLines[r][c]) return;
  vLines[r][c] = current;
  finishTurn(boxesAroundV(r, c));
}

function finishTurn(adjacent) {
  let scored = false;
  for (const [bR, bC] of adjacent) {
    if (!boxes[bR][bC] && isComplete(bR, bC)) {
      boxes[bR][bC] = current;
      scores[current]++;
      scored = true;
    }
  }
  p1El.textContent = 'P1: ' + scores[1];
  p2El.textContent = 'P2: ' + scores[2];

  if (scores[1] + scores[2] === (N - 1) * (N - 1)) {
    gameOver = true;
    const winner = scores[1] === scores[2] ? 'Draw!' : (scores[1] > scores[2] ? 'Player 1 wins!' : 'Player 2 wins!');
    statusEl.textContent = winner + '  (' + scores[1] + '-' + scores[2] + ')';
    draw();
    return;
  }

  if (!scored) current = current === 1 ? 2 : 1;
  turnEl.textContent = 'Player ' + current + "'s turn";
  draw();
}

resetBtn.addEventListener('click', init);
init();
</script>