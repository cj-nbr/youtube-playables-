---
import GameShell from "../components/GameShell.astro";
import { getGame } from "../shared/games";
const game = getGame("dots-and-boxes");
---
<GameShell game={game}>
  <div id="dots" class="mx-auto w-full max-w-[min(420px,90vw)]"></div>
  <div class="mt-3 flex items-center justify-center gap-6 font-mono text-sm">
    <span id="p1-score" class="text-[#19a0ff]">P1: 0</span>
    <span id="turn" class="text-white/80">Player 1's turn</span>
    <span id="p2-score" class="text-[#ff4d4d]">P2: 0</span>
  </div>
</GameShell>

<script>
  import { initGame } from "../games/dots-and-boxes/scripts/game";
  initGame();
</script>
