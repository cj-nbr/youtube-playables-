---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Sign up — YOUTUBE PLAYABLES" description="Create a YOUTUBE PLAYABLES account to save high scores and pick up where you left off.">
  <a href="#main" class="skip-link">Skip to content</a>
  <main id="main" class="mx-auto max-w-[1400px] px-6 py-24">
    <div class="mx-auto max-w-md rounded-xl border border-hairline bg-canvas p-8 shadow-[0_1px_1px_#00000005,0_2px_2px_#0000000a]">
      <h1 class="text-3xl font-semibold tracking-tight text-ink">Create your account.</h1>
      <p class="mt-2 text-body">Sign up free to save high scores and continue your streak.</p>
      <form id="signup-form" class="mt-6 space-y-4">
        <div>
          <label class="mb-1 block text-sm font-medium text-ink" for="username">Username</label>
          <input id="username" type="text" class="h-11 w-full rounded-sm border border-hairline bg-canvas px-3 text-body" placeholder="gamer123" required />
        </div>
        <div>
          <label class="mb-1 block text-sm font-medium text-ink" for="email">Email</label>
          <input id="email" type="email" class="h-11 w-full rounded-sm border border-hairline bg-canvas px-3 text-body" placeholder="you@example.com" required />
        </div>
        <div>
          <label class="mb-1 block text-sm font-medium text-ink" for="password">Password</label>
          <input id="password" type="password" class="h-11 w-full rounded-sm border border-hairline bg-canvas px-3 text-body" placeholder="••••••••" required minlength="8" />
        </div>
        <button type="submit" class="inline-flex h-11 w-full items-center justify-center rounded-pill bg-ink px-6 text-sm font-medium text-white hover:opacity-90">Sign up</button>
      </form>
      <p id="signup-error" class="mt-4 text-sm" style="color:#ee0000;display:none;"></p>
      <p class="mt-4 text-sm text-body">Already have an account? <a href="/login" class="text-link underline-offset-4 hover:underline">Log in</a>.</p>
      <a href="/playables" class="mt-6 inline-block text-sm text-link underline-offset-4 hover:underline">← Back to playables</a>
    </div>
  </main>

  <script is:inline>
    (() => {
      const form = document.getElementById("signup-form");
      const errorEl = document.getElementById("signup-error");
      if (!form) return;

      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        errorEl.style.display = "none";

        const username = document.getElementById("username").value.trim();
        const email = document.getElementById("email").value.trim();
        const password = document.getElementById("password").value;

        try {
          const res = await fetch("http://localhost:4000/api/v1/auth/register", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ username, email, password }),
            credentials: "include",
          });

          const data = await res.json().catch(() => ({}));
          if (!res.ok) {
            errorEl.textContent = data.message || "Sign up failed";
            errorEl.style.display = "block";
            return;
          }

          window.location.href = "/playables";
        } catch (err) {
          errorEl.textContent = "Network error. Please try again.";
          errorEl.style.display = "block";
        }
      });
    })();
  </script>
</Layout>
