---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Terms & Conditions — YOUTUBE PLAYABLES" description="Terms and conditions for using YOUTUBE PLAYABLES — rules, disclaimers, and user responsibilities.">
  <a href="#main" class="skip-link">Skip to content</a>
  <main id="main" class="mx-auto max-w-[1400px] px-6 py-24">
    <h1 class="text-4xl font-semibold tracking-tight text-ink">Terms & Conditions.</h1>
    <p class="mt-4 text-sm text-mute">Last updated: 2026-07-11</p>

    <div class="mt-8 space-y-6 text-body leading-7">
      <h2 class="text-2xl font-semibold tracking-tight text-ink">Acceptance of terms</h2>
      <p>By using YOUTUBE PLAYABLES you agree to these terms. If you do not agree, please do not use the site.</p>

      <h2 class="text-2xl font-semibold tracking-tight text-ink">Use of the site</h2>
      <p>All games are provided free of charge for personal, non-commercial use. You may not copy, distribute, or exploit the games or site content without permission.</p>

      <h2 class="text-2xl font-semibold tracking-tight text-ink">Disclaimer</h2>
      <p>The games are provided “as is” without warranties of any kind. We do not guarantee uninterrupted or error-free operation.</p>

      <h2 class="text-2xl font-semibold tracking-tight text-ink">Limitation of liability</h2>
