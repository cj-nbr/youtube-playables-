---
import Layout from "../layouts/Layout.astro";

const domain = "youtubeplayablescaloriecalculatorfree.com";
---

<Layout>
  <a href="#main" class="skip-link">Skip to content</a>

  <!-- Announcement banner -->
  <div class="flex w-full justify-center border-b border-hairline bg-canvas">
    <a
      href="/"
      class="mx-auto flex max-w-[1400px] items-center gap-2 px-6 py-2 text-sm text-body"
    >
      <span
        class="rounded-full bg-canvas-soft-2 px-2 py-0.5 font-mono text-xs text-mute"
        >NEW</span
      >
      <span>Introducing YOUTUBE PLAYABLES — free playables &amp; a calorie calculator.</span
      >
    </a>
  </div>

  <!-- Nav -->
  <header
    class="sticky top-0 z-50 h-16 border-b border-hairline bg-canvas/80 backdrop-blur-md"
  >
    <nav
      class="mx-auto flex h-16 max-w-[1400px] items-center justify-between px-6"
    >
      <a href="/" class="flex items-center gap-2">
        <svg width="22" height="22" viewBox="0 0 24 24" aria-hidden="true">
          <rect width="24" height="24" rx="5" fill="#171717"></rect>
          <path d="M10 8.5v7l5.5-3.5L10 8.5z" fill="#fff"></path>
        </svg>
        <span class="text-sm font-semibold tracking-tight text-ink"
          >YOUTUBE PLAYABLES</span
        >
      </a>

      <div class="hidden items-center gap-1 md:flex">
        <a href="#playables" class="rounded-full px-3 py-1.5 text-sm text-body hover:text-ink">Playables</a>
        <a href="#calculator" class="rounded-full px-3 py-1.5 text-sm text-body hover:text-ink">Calculator</a>
        <a href="#docs" class="rounded-full px-3 py-1.5 text-sm text-body hover:text-ink">Docs</a>
        <a href="#pricing" class="rounded-full px-3 py-1.5 text-sm text-body hover:text-ink">Pricing</a>
      </div>

      <div class="flex items-center gap-2">
        <a
          href="/login"
          class="hidden h-7 items-center rounded-sm border border-hairline px-3 text-sm font-medium text-ink hover:bg-canvas-soft sm:inline-flex"
          >Log In</a
        >
        <a
          href="/signup"
          class="inline-flex h-7 items-center rounded-sm bg-ink px-3 text-sm font-medium text-white"
          >Sign Up</a
        >
      </div>
    </nav>
  </header>

  <main id="main">
    <!-- Hero -->
    <section class="relative overflow-hidden border-b border-hairline">
      <div class="mesh-gradient pointer-events-none absolute inset-0" aria-hidden="true"></div>
      <div class="relative mx-auto max-w-[1400px] px-6 py-32 text-center md:py-48">
        <span
          class="mb-6 inline-block rounded-full bg-canvas px-3 py-1 font-mono text-xs text-mute shadow-[0_0_0_1px_#00000014]"
          >youtubeplayablescaloriecalculatorfree.com</span
        >
        <h1
          class="mx-auto max-w-3xl text-[40px] font-semibold leading-[1.05] tracking-[-2.4px] text-ink sm:text-[56px] md:text-[72px]"
        >
          hello jhunu.
        </h1>
        <p
          class="mx-auto mt-6 max-w-xl text-lg leading-7 text-body"
        >
          YOUTUBE PLAYABLES brings free YouTube playables and a calorie
          calculator to your browser. One clean surface, built for creators.
        </p>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
          <a
            href="/signup"
            class="inline-flex h-12 items-center rounded-pill bg-ink px-6 text-base font-medium text-white transition-opacity hover:opacity-90"
            >Get started</a
          >
          <a
            href="#calculator"
            class="inline-flex h-12 items-center rounded-pill border border-hairline bg-canvas px-6 text-base font-medium text-ink hover:bg-canvas-soft"
            >Try the calculator</a
          >
        </div>
      </div>
    </section>

    <!-- Three-up feature band -->
    <section id="playables" class="scroll-mt-20 border-b border-hairline bg-canvas-soft px-6 py-24">
      <div class="mx-auto max-w-[1400px]">
        <p class="mb-3 font-mono text-xs uppercase tracking-wide text-mute">
          What you get
        </p>
        <h2 class="max-w-2xl text-3xl font-semibold tracking-[-1.28px] text-ink">
          A compute model for all your playables.
        </h2>
        <div class="mt-12 grid gap-6 md:grid-cols-3">
          <article
            class="rounded-lg border border-hairline bg-canvas p-8 shadow-[0_1px_1px_#00000005,0_2px_2px_#0000000a]"
          >
            <div
              class="mb-5 flex h-10 w-10 items-center justify-center rounded-md bg-canvas-soft-2 text-lg font-semibold text-ink"
              >▶</div
            >
            <h3 class="text-xl font-semibold tracking-tight text-ink">
              Free playables
            </h3>
            <p class="mt-2 text-base leading-6 text-body">
              Instantly play curated YouTube playables — no install, no account
              required to explore.
            </p>
          </article>

          <article
            class="rounded-lg border border-hairline bg-canvas p-8 shadow-[0_1px_1px_#00000005,0_2px_2px_#0000000a]"
          >
            <div
              class="mb-5 flex h-10 w-10 items-center justify-center rounded-md bg-canvas-soft-2 text-lg font-semibold text-ink"
              >∑</div
            >
            <h3 class="text-xl font-semibold tracking-tight text-ink">
              Calorie calculator
            </h3>
            <p class="mt-2 text-base leading-6 text-body">
              Estimate calories per playable session in seconds with a fast,
              focused calculator.
            </p>
          </article>

          <article
            class="rounded-lg border border-hairline bg-canvas p-8 shadow-[0_1px_1px_#00000005,0_2px_2px_#0000000a]"
          >
            <div
              class="mb-5 flex h-10 w-10 items-center justify-center rounded-md bg-canvas-soft-2 text-lg font-semibold text-ink"
              >⚡</div
            >
            <h3 class="text-xl font-semibold tracking-tight text-ink">
              Ship in seconds
            </h3>
            <p class="mt-2 text-base leading-6 text-body">
              Deploy and share your own playables on a global edge network,
              ready the moment you publish.
            </p>
          </article>
        </div>
      </div>
    </section>

    <!-- Dark polarity-flipped band -->
    <section id="calculator" class="scroll-mt-20 bg-ink px-6 py-24 text-white">
      <div class="mx-auto max-w-[1400px]">
        <p class="mb-3 font-mono text-xs uppercase tracking-wide text-white/60">
          Calculator
        </p>
        <h2 class="max-w-2xl text-3xl font-semibold tracking-[-1.28px]">
          A calorie calculator for all workloads.
        </h2>
        <p class="mt-4 max-w-xl text-lg leading-7 text-white/70">
          Plug in your session length and intensity. Get an instant estimate —
          free, forever.
        </p>
        <div class="mt-10 grid gap-4 sm:grid-cols-3">
          <div class="rounded-md bg-white/5 p-6">
            <p class="font-mono text-xs uppercase tracking-wide text-white/50">Input</p>
            <p class="mt-2 text-base text-white/80">Session minutes &amp; intensity</p>
          </div>
          <div class="rounded-md bg-white/5 p-6">
            <p class="font-mono text-xs uppercase tracking-wide text-white/50">Compute</p>
            <p class="mt-2 text-base text-white/80">Real-time estimate</p>
          </div>
          <div class="rounded-md bg-white/5 p-6">
            <p class="font-mono text-xs uppercase tracking-wide text-white/50">Output</p>
            <p class="mt-2 text-base text-white/80">Calories burned</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Soft CTA band -->
    <section id="pricing" class="mesh-soft scroll-mt-20 bg-canvas-soft px-6 py-24">
      <div class="mx-auto max-w-[1400px] text-center">
        <h2 class="mx-auto max-w-2xl text-3xl font-semibold tracking-[-1.28px] text-ink">
          Deploy your first playable in seconds.
        </h2>
        <p class="mx-auto mt-4 max-w-xl text-lg leading-7 text-body">
          Start free on {domain}. No credit card, no friction.
        </p>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
          <a
            href="/signup"
            class="inline-flex h-12 items-center rounded-pill bg-ink px-6 text-base font-medium text-white hover:opacity-90"
            >Start deploying</a
          >
        </div>
      </div>
    </section>
  </main>

  <!-- Footer -->
  <footer id="docs" class="scroll-mt-20 border-t border-hairline bg-canvas px-6 py-16">
    <div class="mx-auto grid max-w-[1400px] gap-10 md:grid-cols-4">
      <div class="md:col-span-1">
        <div class="flex items-center gap-2">
          <svg width="22" height="22" viewBox="0 0 24 24" aria-hidden="true">
            <rect width="24" height="24" rx="5" fill="#171717"></rect>
            <path d="M10 8.5v7l5.5-3.5L10 8.5z" fill="#fff"></path>
          </svg>
          <span class="text-sm font-semibold tracking-tight text-ink"
            >YOUTUBE PLAYABLES</span
          >
        </div>
        <p class="mt-4 text-sm text-body">
          Free YouTube playables &amp; calorie calculator.
        </p>
      </div>

      <div>
        <p class="mb-3 font-mono text-xs uppercase tracking-wide text-mute">Product</p>
        <ul class="space-y-2 text-sm text-body">
          <li><a href="#playables" class="hover:text-ink">Playables</a></li>
          <li><a href="#calculator" class="hover:text-ink">Calculator</a></li>
          <li><a href="#pricing" class="hover:text-ink">Pricing</a></li>
        </ul>
      </div>

      <div>
        <p class="mb-3 font-mono text-xs uppercase tracking-wide text-mute">Resources</p>
        <ul class="space-y-2 text-sm text-body">
          <li><a href="#docs" class="hover:text-ink">Docs</a></li>
          <li><a href="/changelog" class="hover:text-ink">Changelog</a></li>
          <li><a href="/support" class="hover:text-ink">Support</a></li>
        </ul>
      </div>

      <div>
        <p class="mb-3 font-mono text-xs uppercase tracking-wide text-mute">Domain</p>
        <a
          href={`https://${domain}`}
          class="text-sm text-link underline-offset-4 hover:underline"
          >{domain}</a
        >
      </div>
    </div>

    <div
      class="mx-auto mt-12 flex max-w-[1400px] flex-col items-start justify-between gap-2 border-t border-hairline pt-6 text-sm text-mute sm:flex-row sm:items-center"
    >
      <span>© {new Date().getFullYear()} YOUTUBE PLAYABLES. All rights reserved.</span>
      <span class="font-mono text-xs">hello jhunu.</span>
    </div>
  </footer>
</Layout>
