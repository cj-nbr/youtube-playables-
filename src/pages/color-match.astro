---
import GameShell from "../components/GameShell.astro";
import { getGame } from "../shared/games";
const game = getGame("color-match");
---
<GameShell game={game}>
  <div id="color-match" class="mx-auto w-full max-w-[min(400px,100vw-2rem)]">
    <div class="mb-4">
      <div class="mb-1 flex justify-between text-sm text-white/70"><span>Target</span><span id="target-hex">#000000</span></div>
      <div id="target-swatch" class="h-16 rounded-lg border-2 border-white/20 sm:h-20"></div>
    </div>
    <div class="mb-4">
      <div class="mb-1 flex justify-between text-sm text-white/70"><span>Your Mix</span><span id="mix-hex">#000000</span></div>
      <div id="mix-swatch" class="h-16 rounded-lg border-2 border-white/20 sm:h-20"></div>
    </div>
    <div class="mb-4 space-y-3">
      <div>
        <div class="flex justify-between text-sm text-white/70"><span>R</span><span id="r-val">128</span></div>
        <input type="range" id="r-slider" min="0" max="255" value="128" class="w-full accent-[#ff4444]" aria-label="Red" />
      </div>
      <div>
        <div class="flex justify-between text-sm text-white/70"><span>G</span><span id="g-val">128</span></div>
        <input type="range" id="g-slider" min="0" max="255" value="128" class="w-full accent-[#44ff44]" aria-label="Green" />
      </div>
      <div>
        <div class="flex justify-between text-sm text-white/70"><span>B</span><span id="b-val">128</span></div>
        <input type="range" id="b-slider" min="0" max="255" value="128" class="w-full accent-[#4444ff]" aria-label="Blue" />
      </div>
    </div>
    <div class="mb-4 flex gap-2">
      <button id="submit-btn" class="flex-1 h-10 rounded-pill bg-white font-medium text-ink hover:opacity-90">Submit</button>
      <button id="skip-btn" class="flex-1 h-10 rounded-pill border border-white/30 text-white hover:bg-white/10">Skip</button>
    </div>
    <div class="flex justify-between text-sm text-white/70">
      <span>Time: <span id="timer">30</span>s</span>
      <span>Score: <span id="score">0</span></span>
      <span>Round: <span id="round">1</span>/10</span>
    </div>
  </div>
</GameShell>

<script>
  import { initGame } from "../games/color-match/scripts/game";
  initGame();
</script>
