---
import Layout from "../../layouts/Layout.astro";
import { blogPosts, recentBlogPosts } from "../../shared/blog";
---

<Layout title="Blog — YOUTUBE PLAYABLES" description="Free guides, strategies, and articles about brain games, puzzle games, and browser-based play.">
  <a href="#main" class="skip-link">Skip to content</a>

  <header class="sticky top-0 z-50 h-16 border-b border-hairline bg-canvas/80 backdrop-blur-md">
    <nav class="mx-auto flex h-16 max-w-[1400px] items-center justify-between px-6">
      <a href="/" class="flex items-center gap-2">
        <svg width="22" height="22" viewBox="0 0 24 24" aria-hidden="true">
          <rect width="24" height="24" rx="5" fill="#171717"></rect>
          <path d="M10 8.5v7l5.5-3.5L10 8.5z" fill="#fff"></path>
        </svg>
        <span class="text-sm font-semibold tracking-tight text-ink">YOUTUBE PLAYABLES</span>
      </a>
      <div class="hidden items-center gap-1 md:flex">
        <a href="/playables" class="rounded-full bg-canvas-soft px-3 py-1.5 text-sm text-ink">Playables</a>
        <a href="/blog" class="rounded-full bg-canvas-soft px-3 py-1.5 text-sm text-ink">Blog</a>
      </div>
      <div class="flex items-center gap-2">
        <a href="/login" class="hidden h-7 items-center rounded-sm border border-hairline px-3 text-sm font-medium text-ink hover:bg-canvas-soft sm:inline-flex">Log In</a>
        <a href="/signup" class="inline-flex h-7 items-center rounded-sm bg-ink px-3 text-sm font-medium text-white">Sign Up</a>
      </div>
    </nav>
  </header>

  <main id="main" class="mx-auto max-w-[1400px] px-6 py-16">
    <h1 class="text-[40px] font-semibold tracking-[-2.4px] text-ink sm:text-[56px]">Blog.</h1>
    <p class="mt-4 max-w-xl text-lg leading-7 text-body">Guides, strategies, and insights about brain games, puzzle games, and browser-based play.</p>

    <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {blogPosts.map((post) => (
        <a href={`/blog/${post.slug}`} class="group flex flex-col rounded-lg border border-hairline bg-canvas p-6 shadow-[0_1px_1px_#00000005,0_2px_2px_#0000000a] transition hover:-translate-y-0.5 hover:shadow-[0_2px_2px_#0000000a,0_8px_8px_-8px_#0000000a]">
          <span class="rounded-full bg-link-bg-soft px-2 py-0.5 font-mono text-xs text-link-deep w-fit">{post.category}</span>
          <h2 class="mt-3 text-lg font-semibold tracking-tight text-ink group-hover:text-link">{post.title}</h2>
          <p class="mt-2 flex-1 text-sm leading-6 text-body">{post.description}</p>
          <span class="mt-4 font-mono text-xs text-mute">{post.date}</span>
        </a>
      ))}
    </div>
  </main>

  <footer class="border-t border-hairline bg-canvas px-6 py-16">
    <div class="mx-auto flex max-w-[1400px] flex-col items-start justify-between gap-2 border-t border-hairline pt-6 text-sm text-mute sm:flex-row sm:items-center">
      <span>© {new Date().getFullYear()} YOUTUBE PLAYABLES. All rights reserved.</span>
      <span class="font-mono text-xs">youtubeplayables</span>
    </div>
  </footer>
</Layout>
