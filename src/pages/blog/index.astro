---
import Layout from "../../layouts/Layout.astro";
import { blogPosts, recentBlogPosts } from "../../shared/blog";
---

<Layout title="Blog — YOUTUBE PLAYABLES" description="Free guides, strategies, and articles about brain games, puzzle games, and browser-based play.">
  <a href="#main" class="skip-link">Skip to content</a>

  <main id="main" class="mx-auto max-w-[1400px] px-6 py-16">
    <h1 class="text-[40px] font-semibold tracking-[-2.4px] text-ink sm:text-[56px]">Blog.</h1>
    <p class="mt-4 max-w-xl text-lg leading-7 text-body">Guides, strategies, and insights about brain games, puzzle games, and browser-based play.</p>

    <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {blogPosts.map((post) => (
        <a href={`/blog/${post.slug}`} class="card card-hover p-6">
          <span class="rounded-full bg-link-bg-soft px-2 py-0.5 font-mono text-xs text-link-deep w-fit">{post.category}</span>
          <h2 class="mt-3 text-lg font-semibold tracking-tight text-ink">{post.title}</h2>
          <p class="mt-2 flex-1 text-sm leading-6 text-body">{post.description}</p>
          <span class="mt-4 font-mono text-xs text-mute">{post.date}</span>
        </a>
      ))}
    </div>
  </main>
</Layout>
