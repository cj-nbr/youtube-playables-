---
import GameShell from "../components/GameShell.astro";
import { getGame } from "../shared/games";
const game = getGame("block-blast");
---
<GameShell game={game}>
  <div id="block-blast" class="mx-auto w-full max-w-[min(400px,100vw-2rem)]"></div>
</GameShell>

<script>
  import { initGame } from "../games/block-blast/scripts/game";
  initGame();
</script>
