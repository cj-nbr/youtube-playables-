---
import GameShell from "../components/GameShell.astro";

const game = {
  title: "Block Blast",
  description: "Clear groups of matching colored blocks. Bigger groups score exponentially more. Plan ahead for massive combos!",
  genre: ["Puzzle", "Strategy"],
  guide: [
    { heading: "Goal", body: "Clear the board by removing groups of 2+ adjacent blocks of the same color. Score = groupSize²." },
    { heading: "How to play", body: "Click any block in a connected group (orthogonal only) of 2 or more same-colored blocks. The group disappears, blocks above fall down, and empty columns shift left." },
    { heading: "Strategy", body: "Larger groups score much more (3²=9, 5²=25, 10²=100). Set up cascades by clearing below first. Avoid leaving singletons." },
    { heading: "Example", body: "A 4-block red group = 16 pts. If it causes a 5-block blue group to form and clear = +25. Chain them for big scores!" },
  ],
};
---

<GameShell title={game.title} description={game.description} genre={game.genre} guide={game.guide}>
  <div id="block-blast" class="w-full max-w-[400px] mx-auto"></div>
</GameShell>

<script>
const COLS = 10;
const ROWS = 12;
const COLORS = ['#ff4444', '#44ff44', '#4488ff', '#ffcc00', '#ff66ff', '#00ffff'];
const CELL = 36;

const boardEl = document.getElementById('block-blast');
const resetBtn = document.getElementById('reset-btn');
const statusEl = document.getElementById('status');

let grid = [];
let score = 0;
let selected = null;
let animating = false;

function createGrid() {
  grid = [];
  for (let c = 0; c < COLS; c++) {
    grid[c] = [];
    for (let r = 0; r < ROWS; r++) {
      grid[c][r] = Math.floor(Math.random() * COLORS.length);
    }
  }
}

function draw() {
  boardEl.innerHTML = '';
  boardEl.style.width = (COLS * CELL) + 'px';
  boardEl.style.height = (ROWS * CELL) + 'px';
  boardEl.style.position = 'relative';

  for (let c = 0; c < COLS; c++) {
    for (let r = 0; r < ROWS; r++) {
      const colorIdx = grid[c][r];
      if (colorIdx === null) continue;
      const cell = document.createElement('div');
      cell.className = 'absolute rounded border-2 border-white/10';
      cell.style.left = (c * CELL) + 'px';
      cell.style.bottom = (r * CELL) + 'px';
      cell.style.width = (CELL - 2) + 'px';
      cell.style.height = (CELL - 2) + 'px';
      cell.style.background = COLORS[colorIdx];
      cell.style.boxShadow = 'inset 0 -2px 4px rgba(0,0,0,.3), inset 0 2px 4px rgba(255,255,255,.1)';
      cell.style.transition = 'transform .15s ease, opacity .15s ease';
      cell.dataset.c = c;
      cell.dataset.r = r;
      cell.addEventListener('click', () => handleClick(c, r));
      boardEl.appendChild(cell);
    }
  }
  statusEl.textContent = 'Score: ' + score;
}

function getGroup(c, r) {
  const color = grid[c][r];
  if (color === null) return [];
  const visited = new Set();
  const stack = [[c, r]];
  const group = [];
  while (stack.length) {
    const [cc, rr] = stack.pop();
    const key = cc + ',' + rr;
    if (visited.has(key)) continue;
    if (cc < 0 || cc >= COLS || rr < 0 || rr >= ROWS) continue;
    if (grid[cc][rr] !== color) continue;
    visited.add(key);
    group.push([cc, rr]);
    stack.push([cc+1, rr], [cc-1, rr], [cc, rr+1], [cc, rr-1]);
  }
  return group;
}

function applyGravity() {
  for (let c = 0; c < COLS; c++) {
    let writeRow = 0;
    for (let r = 0; r < ROWS; r++) {
      if (grid[c][r] !== null) {
        if (writeRow !== r) {
          grid[c][writeRow] = grid[c][r];
          grid[c][r] = null;
        }
        writeRow++;
      }
    }
  }
}

function shiftColumns() {
  let writeCol = 0;
  for (let c = 0; c < COLS; c++) {
    if (grid[c][0] !== null) {
      if (writeCol !== c) {
        grid[writeCol] = grid[c];
        grid[c] = Array(ROWS).fill(null);
      }
      writeCol++;
    }
  }
}

async function handleClick(c, r) {
  if (animating) return;
  const group = getGroup(c, r);
  if (group.length < 2) return;

  animating = true;
  // Animate removal
  group.forEach(([gc, gr]) => {
    const cell = boardEl.querySelector(`[data-c="${gc}"][data-r="${gr}"]`);
    if (cell) {
      cell.style.transform = 'scale(0)';
      cell.style.opacity = '0';
    }
  });
  await new Promise(res => setTimeout(res, 150));

  // Remove from grid
  group.forEach(([gc, gr]) => grid[gc][gr] = null);
  score += group.length * group.length;
  applyGravity();
  shiftColumns();
  draw();
  animating = false;

  // Check for any moves left
  if (!hasMoves()) {
    setTimeout(() => {
      statusEl.textContent = 'No moves left! Final Score: ' + score;
    }, 200);
  }
}

function hasMoves() {
  for (let c = 0; c < COLS; c++) {
    for (let r = 0; r < ROWS; r++) {
      if (grid[c][r] !== null && getGroup(c, r).length >= 2) return true;
    }
  }
  return false;
}

function reset() {
  score = 0;
  createGrid();
  draw();
  statusEl.textContent = 'Score: 0';
}

resetBtn.addEventListener('click', reset);
reset();
</script>