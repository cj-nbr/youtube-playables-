---
import GameShell from "../components/GameShell.astro";
import { getGame } from "../shared/games";
const game = getGame("chess");
---
<GameShell game={game}>
  <div id="chess-board" class="mx-auto"></div>
</GameShell>

<style>
  #chess-board {
    display: grid;
    grid-template-columns: repeat(8, 1fr);
    grid-template-rows: repeat(8, 1fr);
    width: 100%;
    max-width: min(460px, 90vw);
    aspect-ratio: 1 / 1;
    border: 2px solid #00ffd8;
    border-radius: 6px;
    overflow: hidden;
  }
  #chess-board > div {
    width: 100%;
    height: 100%;
    box-sizing: border-box;
  }
</style>

<script>
  import { initGame } from "../games/chess/scripts/game";
  initGame();
</script>
