---
import Layout from "../layouts/Layout.astro";
import Logo from "../components/Logo.astro";

const title = "Page not found — YOUTUBE PLAYABLES";
---

<Layout title={title}>
  <a href="#main" class="skip-link">Skip to content</a>

  <header class="sticky top-0 z-50 h-16 border-b border-hairline bg-canvas/80 backdrop-blur-md">
    <nav class="mx-auto flex h-16 max-w-[1400px] items-center justify-between px-6">
      <a href="/" class="flex items-center gap-2">
        <Logo />
        <span class="text-sm font-semibold tracking-tight text-ink">YOUTUBE PLAYABLES</span>
      </a>
      <div class="hidden items-center gap-1 md:flex">
        <a href="/playables" class="rounded-full bg-canvas-soft px-3 py-1.5 text-sm text-ink">Playables</a>
      </div>
      <div class="flex items-center gap-2">
        <a href="/login" class="hidden h-7 items-center rounded-sm border border-hairline px-3 text-sm font-medium text-ink hover:bg-canvas-soft sm:inline-flex">Log In</a>
        <a href="/signup" class="inline-flex h-7 items-center rounded-sm bg-ink px-3 text-sm font-medium text-white">Sign Up</a>
      </div>
    </nav>
  </header>

  <main id="main" class="relative overflow-hidden border-b border-hairline">
    <div class="mesh-gradient pointer-events-none absolute inset-0" aria-hidden="true"></div>
    <div class="relative mx-auto max-w-[1400px] px-6 py-24 text-center md:py-32">
      <span class="mb-6 inline-block rounded-full bg-canvas px-3 py-1 font-mono text-xs text-mute shadow-[0_0_0_1px_#00000014]">404</span>
      <h1 class="mx-auto max-w-3xl text-[48px] font-semibold leading-[1.05] tracking-[-2.4px] text-ink sm:text-[64px]">
        Page not found.
      </h1>
      <p class="mx-auto mt-6 max-w-xl text-lg leading-7 text-body">
        The page you’re looking for doesn’t exist or has been moved. Pick a game below and keep playing.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <a href="/" class="btn btn-primary h-12 px-6 text-base">Go home</a>
        <a href="/playables" class="btn btn-ghost h-12 px-6 text-base">Browse playables</a>
      </div>
    </div>
  </main>
</Layout>
