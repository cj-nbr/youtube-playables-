---
import "../styles/global.css";
import Seo from "../components/Seo.astro";
import type { GameMeta } from "../shared/types";
import { SITE_URL, SITE_NAME } from "../shared/config";

interface Props {
  title?: string;
  description?: string;
  game?: GameMeta;
}

const {
  title = "YOUTUBE PLAYABLES",
  description = "YOUTUBE PLAYABLES — free YouTube playables.",
  game,
} = Astro.props;

const path = Astro.url.pathname;
const isPlayables = path === "/playables";
const isBlog = path.startsWith("/blog");
const isArticle = isBlog && !path.endsWith("/blog");

const orgLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: SITE_NAME,
  url: SITE_URL,
  logo: `${SITE_URL}/favicon.svg`,
  description: "Free browser-native HTML5 games.",
};

const websiteLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: SITE_NAME,
  url: SITE_URL,
  description: "Free browser-native HTML5 games.",
  potentialAction: {
    "@type": "SearchAction",
    target: `${SITE_URL}/search?q={search_term_string}`,
    "query-input": "required name=search_term_string",
  },
};

const collectionPageLd = isPlayables
  ? {
      "@context": "https://schema.org",
      "@type": "CollectionPage",
      name: "Playables",
      description: "A growing library of quick, free, browser-native playables.",
      url: `${SITE_URL}/playables`,
      isPartOf: { "@type": "WebSite", name: SITE_NAME, url: SITE_URL },
    }
  : null;

const webPageLd = !game && (isBlog || path === "/about" || path === "/contact" || path === "/privacy" || path === "/terms")
  ? {
      "@context": "https://schema.org",
      "@type": "WebPage",
      name: title,
      description,
      url: `${SITE_URL}${path}`,
      isPartOf: { "@type": "WebSite", name: SITE_NAME, url: SITE_URL },
    }
  : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    {game && <Seo game={game} />}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600&family=Geist+Mono:wght@400&display=swap"
      rel="stylesheet"
    />

    <script type="application/ld+json" is:inline set:html={JSON.stringify(orgLd)}></script>
    <script type="application/ld+json" is:inline set:html={JSON.stringify(websiteLd)}></script>
    {collectionPageLd && <script type="application/ld+json" is:inline set:html={JSON.stringify(collectionPageLd)}></script>}
    {webPageLd && <script type="application/ld+json" is:inline set:html={JSON.stringify(webPageLd)}></script>}
  </head>
  <body>
    <slot />
  </body>
</html>
