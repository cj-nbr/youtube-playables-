---
import "../styles/global.css";
import Seo from "../components/Seo.astro";
import type { GameMeta } from "../shared/types";

interface Props {
  title?: string;
  description?: string;
  /** When provided, full per-game SEO (canonical, OG, JSON-LD) is rendered. */
  game?: GameMeta;
}

const {
  title = "YOUTUBE PLAYABLES",
  description = "YOUTUBE PLAYABLES — free YouTube playables.",
  game,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    {game && <Seo game={game} />}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600&family=Geist+Mono:wght@400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>
