---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "YOUTUBE PLAYABLES",
  description = "YOUTUBE PLAYABLES — free YouTube playables and a calorie calculator. hello jhunu.",
} = Astro.props;

const domain = "https://youtubeplayablescaloriecalculatorfree.com";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={domain} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600&family=Geist+Mono:wght@400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>
